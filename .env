PROJECT_NAME=mihomo-gateway
TZ=Asia/Shanghai

MIHOMO_IMAGE=metacubex/mihomo:latest
ZASHBOARD_IMAGE=ghcr.io/zephyruso/zashboard:latest
SUBCONVERTER_IMAGE=aethersailor/subconverter-extended:latest

# ★ 改成你自己路由器的局域网 IP（客户端代理地址、Dashboard/API 访问地址、
#   SubConverter-Extended 的 MANAGED_CONFIG_PREFIX 都依赖这个值）
HOST_IP=192.168.1.1

MIXED_PORT=9070
SOCKS_PORT=9071
HTTP_PORT=9072
API_PORT=9073
DASHBOARD_PORT=9075
DNS_PORT=1053
SUBCONVERTER_PORT=25500

CHINA_DNS=192.168.1.3

FOREIGN_DOH=https://1.1.1.1/dns-query
FOREIGN_DOH_FALLBACK=https://dns.google/dns-query

# ============================================================
# 订阅配置
# ============================================================
# 粘贴你的原始订阅链接（脚本会自动用 mihomo UA 请求；若内容不是 Mihomo 可用格式，
# 会自动解析出节点链接，交给本地 SubConverter-Extended 转换成节点列表）
# 如果链接本身包含 & ? = # 等特殊字符，必须用英文双引号包起来，否则 sh 在读取
# .env 时会把 & 当作后台命令分隔符处理，截断链接。
# 例：SUBSCRIPTION_URL="https://example.com/api/v1/client/subscribe?token=xxx&flag=clash"
SUBSCRIPTION_URL=

# 订阅转换统一使用本地自建的 SubConverter-Extended（见下方 subconverter 相关配置），
# 不再依赖 api.v1.mk 等公共后端。

# ============================================================
# API 认证密钥
# ============================================================
# 运行 scripts/generate-secret.sh 自动生成并填充此项
SECRET=
