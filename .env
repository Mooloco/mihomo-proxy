PROJECT_NAME=mihomo-gateway
TZ=Asia/Shanghai

MIHOMO_IMAGE=metacubex/mihomo:latest
ZASHBOARD_IMAGE=ghcr.io/zephyruso/zashboard:latest

HOST_IP=192.168.1.1

MIXED_PORT=9070
SOCKS_PORT=9071
HTTP_PORT=9072
API_PORT=9073
DASHBOARD_PORT=9075
DNS_PORT=1053

CHINA_DNS=192.168.1.3

FOREIGN_DOH=https://1.1.1.1/dns-query
FOREIGN_DOH_FALLBACK=https://dns.google/dns-query

# ============================================================
# 订阅配置
# ============================================================
# 粘贴你的订阅链接（脚本会自动用 mihomo UA 请求；若内容不可用则自动走转换）
SUBSCRIPTION_URL=

# subconverter 转换后端（订阅无法直接使用时的备用转换，可替换为自建）
# 可用公共后端：https://sub.xeton.dev  https://api.v1.mk  https://sub.mi200.top
SUBCONVERTER_URL=https://api.v1.mk

# ============================================================
# API 认证密钥
# ============================================================
# 运行 scripts/generate-secret.sh 自动生成并填充此项
SECRET=
